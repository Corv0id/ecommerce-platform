# Django
SECRET_KEY=change-me-in-production
DEBUG=1
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0

# PostgreSQL
# Use localhost when Django runs on your machine (venv) and Postgres listens on the host
# (Compose publishes db:5432, or you run Postgres locally).
# Inside the Compose *web* container, docker-compose.yml sets POSTGRES_HOST=db — no change needed there.
# Si vous n'avez pas Docker, vous pouvez utiliser SQLite en mettant USE_SQLITE=True
USE_SQLITE=True

POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_dev_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
# localhost when Redis runs on the host or Compose publishes redis:6379.
# Compose overrides REDIS_URL for the web service to redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (comma-separated origins for browser clients)
CORS_ALLOWED_ORIGINS=http://localhost:3000
